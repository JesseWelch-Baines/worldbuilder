div class="flex flex-row justify-between pr-2 rounded-sm hover:bg-gray-200"
  = link_to url_for(@item), class: "w-full p-3" do
    p = @item.name.present? ? @item.name : @item.description.to_plain_text.truncate(75, separator: ' ')

  - if @links[:move_up_path].present? && @index != 0
    = link_to @links[:move_up_path], class: "text-lg hover:text-blue-500 text-center px-2" do
      i class="h-full pt-4 fas fa-fw fa-arrow-up fa-xs"
  - if @links[:move_down_path].present? && @index + 1 != @count
    = link_to @links[:move_down_path], class: "text-lg hover:text-blue-500 text-center px-2" do
      i class="h-full pt-4 fas fa-fw fa-arrow-down fa-xs"
    
  - if @links[:change_to_path].present?
    = link_to @links[:change_to_path], data: {turbo_method: :post}, class: "text-lg hover:text-blue-500 text-center px-2" do
      i class="h-full pt-4 fas fa-fw fa-door-open fa-xs"

  = link_to edit_polymorphic_path(@item), class: "text-lg hover:text-blue-500 text-center px-2" do
    i class="h-full pt-4 fas fa-fw fa-edit fa-xs"