= form_with(model: document, local: true) do |form|
  div class="px-6 my-5"
    = render(partial: 'layouts/notices/errors', locals: {record: document})
    div class="pb-5"
      p class="font-semibold" = form.label :name
      p = form.text_field :name
    div class="flex flex-row justify-between"
      = form.submit class: "button"
      - if @document.persisted?
        = link_to "Delete", document_path(@document), method: :delete, data: { confirm: 'Are you sure?' }, type: "button", class: "button"