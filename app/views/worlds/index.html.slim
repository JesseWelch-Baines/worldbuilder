- if @worlds.any?
  div class="flex flex-row justify-center"
    div class="w-1/2 p-2 bg-gray-300 rounded-sm"
      - @worlds.each do |world|
        = render ListItemComponent.new(item: world, index: 0, count: @worlds.size, links: item_list_links(world))


div class="flex flex-row justify-center"
  div class="w-1/2 pt-5"
    = link_to "New World", new_world_path, class: "button"